EJERCICIO 7 :

int CountStrongerPairs(int[] powerLevels)
{

    int count = 0;      //+1 asignamiento
    
    for (int i = 0; i < powerLevels.Length; i++)    //+1 asignamiento + (N+1) comparacion + N incremento
    {
            for (int j = 0; j < powerLevels.Length; j++)        //+1 asignamiento + (N+1) comparacion + N incremento
            {
            if (powerLevels[i] > powerLevels[j])        // +N indice + 1 comparacion + N indice
            }
          count++;     //+N
        }
    }
    return count;      //+1
}

