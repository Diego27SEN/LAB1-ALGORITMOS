EJERCICIO 3 :

int CalculateInteractionScore(int[ ] players )
{
    int score = 0;     //+1 asignamiento
    {
    for (int i = 0; i < players. Length; i++)    //   +1 incremento + (N+1)comparacion + N incremento
    {
          for (int j = i + 1; j < players.Length; j++)   // +1 asignamiento + (N+1) comparacion + N
           {
            int interaction = players[i] + players[j];   // +1 asignamiento + N + 1 por incremento + N
            score += interaction;    // +1 incremento + 1 asignacion
           }
    }
    return score; //+1 
}

